export default ADVENTURES
export { ADVENTURES as allAdventures }

export function getAdventuresByCategory(category: string): Adventure[] {
  return ADVENTURES.filter(a => a.category === category)
}

export function getAdventuresByContinent(continent: string): Adventure[] {
  return ADVENTURES.filter(a => a.location.continent.toLowerCase().replace(/ /g, '-') === continent.toLowerCase())
}

export function getAdventuresByCountry(country: string): Adventure[] {
  return ADVENTURES.filter(a => a.location.country.toLowerCase() === country.toLowerCase())
}

export function getFeaturedAdventures(): Adventure[] {
  return ADVENTURES.filter(a => a.featured)
}

export function searchAdventures(query: string): Adventure[] {
  const q = query.toLowerCase()
  return ADVENTURES.filter(a => 
    a.title.toLowerCase().includes(q) ||
    a.description.toLowerCase().includes(q) ||
    a.location.country.toLowerCase().includes(q) ||
    a.location.continent.toLowerCase().includes(q) ||
    a.category.toLowerCase().includes(q)
  )
}

export function getAdventureById(id: string): Adventure | undefined {
  return ADVENTURES.find(a => a.id === id)
}

export function getAllCountries(): string[] {
  return [...new Set(ADVENTURES.map(a => a.location.country))].sort()
}

export function getAllRegions(): string[] {
  return [...new Set(ADVENTURES.map(a => a.location.region))].sort()
}

export function getAllContinents(): string[] {
  return [...new Set(ADVENTURES.map(a => a.location.continent))]
}
